#!/usr/bin/env python3
"""bq CLI shim — routes `bq query` invocations through google-cloud-bigquery.

Reason this exists: the real `bq` CLI from the gcloud SDK refuses to use ADC
user OAuth credentials in headless CI ("no active account selected" — it
checks `gcloud auth list`, which is empty when only ADC is configured). The
Python google-cloud-bigquery client honors GOOGLE_APPLICATION_CREDENTIALS
natively, so user refresh tokens just work. This shim translates the
orchestrator's `bq query ...` calls into Python BQ client calls.

Drop-in usage: place this file as `bq` (executable, chmod +x) on PATH earlier
than the real bq binary. The orchestrator's Bash invocations like
    bq query --use_legacy_sql=false --format=prettyjson --max_rows=N \\
       --parameter='alternate_name:STRING:foo' \\
       --parameter='start_date:DATE:2026-05-01' \\
       < query.sql
are intercepted; output goes to stdout in the same `--format=prettyjson` shape
the orchestrator expects.

Scope: only `bq query` is implemented. Other subcommands (`bq ls`, `bq mk`,
`bq show`, etc.) exit with an error.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
from datetime import date, datetime
from decimal import Decimal
from typing import Any

try:
    from google.cloud import bigquery
except ImportError:
    print("[bq-shim] google-cloud-bigquery not installed; run `pip install google-cloud-bigquery db-dtypes`", file=sys.stderr)
    sys.exit(2)


# ---------- Parameter parsing ----------

_ARRAY_STRUCT_RE = re.compile(r'^ARRAY<STRUCT<(.+)>>$', re.IGNORECASE)
_ARRAY_RE = re.compile(r'^ARRAY<(.+)>$', re.IGNORECASE)
_STRUCT_FIELD_SPLIT_RE = re.compile(r',\s*(?![^<>]*>)')  # split on commas NOT inside <>


def _scalar(value: str, type_str: str) -> Any:
    """Convert a CLI string value to a Python value of the given BQ scalar type."""
    t = type_str.upper().strip()
    if value == 'NULL' or value is None:
        return None
    if t == 'STRING':
        return value
    if t == 'BOOL' or t == 'BOOLEAN':
        return value.lower() in ('true', '1', 'yes', 't')
    if t in ('INT64', 'INTEGER', 'INT'):
        return int(value)
    if t in ('FLOAT64', 'FLOAT', 'NUMERIC', 'BIGNUMERIC'):
        return float(value)
    if t == 'DATE':
        return date.fromisoformat(value)
    if t == 'DATETIME':
        return datetime.fromisoformat(value)
    if t == 'TIMESTAMP':
        # bq accepts ISO with offset; Python's fromisoformat handles +00:00 since 3.11
        return datetime.fromisoformat(value.replace('Z', '+00:00'))
    if t == 'BYTES':
        import base64
        return base64.b64decode(value)
    raise ValueError(f"[bq-shim] Unsupported scalar type: {type_str}")


def _parse_struct_field_defs(inner: str) -> list[tuple[str, str]]:
    """Parse `name TYPE, name TYPE` (inside STRUCT<>) into list of (name, type)."""
    fields = []
    for pair in _STRUCT_FIELD_SPLIT_RE.split(inner):
        pair = pair.strip()
        if not pair:
            continue
        # First whitespace separates name and type. Type may contain spaces (e.g. "ARRAY<STRING>")
        sp = pair.find(' ')
        if sp < 0:
            raise ValueError(f"[bq-shim] Bad STRUCT field def (no type): {pair!r}")
        fields.append((pair[:sp], pair[sp+1:].strip()))
    return fields


def parse_parameter(param_str: str) -> bigquery.QueryParameter:
    """Parse a single `--parameter='NAME:TYPE:VALUE'` string into a QueryParameter."""
    # Split on the first two colons. TYPE may contain '<>,' but never bare ':'.
    parts = param_str.split(':', 2)
    if len(parts) != 3:
        raise ValueError(f"[bq-shim] Bad --parameter format (expected NAME:TYPE:VALUE): {param_str!r}")
    name, type_str, value_str = parts[0], parts[1].strip(), parts[2]

    # ARRAY<STRUCT<a TYPE, b TYPE>>
    m = _ARRAY_STRUCT_RE.match(type_str)
    if m:
        field_defs = _parse_struct_field_defs(m.group(1))
        try:
            items = json.loads(value_str)
        except json.JSONDecodeError as e:
            raise ValueError(f"[bq-shim] ARRAY<STRUCT> value must be JSON: {e}; got {value_str!r}")
        struct_params = []
        for item in items:
            fields = []
            for fname, ftype in field_defs:
                v = item.get(fname)
                if v is None:
                    fields.append(bigquery.ScalarQueryParameter(fname, ftype.upper(), None))
                else:
                    fields.append(bigquery.ScalarQueryParameter(fname, ftype.upper(), _scalar(str(v), ftype)))
            struct_params.append(bigquery.StructQueryParameter(None, *fields))
        # ArrayQueryParameter with struct values — pass struct_type via the elements
        return bigquery.ArrayQueryParameter(name, 'STRUCT', struct_params)

    # ARRAY<scalar>
    m = _ARRAY_RE.match(type_str)
    if m:
        scalar_type = m.group(1).strip()
        if value_str.startswith('['):
            values = json.loads(value_str)
        else:
            values = [v.strip() for v in value_str.split(',') if v.strip()]
        return bigquery.ArrayQueryParameter(name, scalar_type.upper(), [_scalar(str(v), scalar_type) for v in values])

    # Scalar
    return bigquery.ScalarQueryParameter(name, type_str.upper(), _scalar(value_str, type_str))


# ---------- Output formatting (match `bq --format=prettyjson`) ----------

def _serialize_value(v: Any) -> Any:
    """Convert a Python row value to the form bq's prettyjson uses.

    bq stringifies numbers (returns "123" not 123) — we mirror that so downstream
    Python code that does `float(row['x'])` works unchanged. dates/datetimes are
    ISO strings. None stays None (renders as `null` in JSON).
    """
    if v is None:
        return None
    if isinstance(v, bool):
        return 'true' if v else 'false'
    if isinstance(v, (int, float, Decimal)):
        # bq returns numbers as strings in prettyjson. Use repr for float to avoid trailing-zero loss.
        return str(v)
    if isinstance(v, (date, datetime)):
        return v.isoformat()
    if isinstance(v, bytes):
        import base64
        return base64.b64encode(v).decode('ascii')
    if isinstance(v, dict):
        return {k: _serialize_value(val) for k, val in v.items()}
    if isinstance(v, list):
        return [_serialize_value(x) for x in v]
    return v


def _row_to_dict(row, schema) -> dict:
    """Convert a BQ Row to a dict, preserving column order from the schema."""
    out = {}
    for field in schema:
        out[field.name] = _serialize_value(row[field.name])
    return out


# ---------- query subcommand ----------

def query_command(args, sql: str) -> None:
    """Execute `bq query` via google-cloud-bigquery and write prettyjson to stdout."""
    # Project ID resolution: prefer --project_id, then env, then ADC default.
    project = args.project_id or os.environ.get('GOOGLE_CLOUD_PROJECT') or os.environ.get('CLOUDSDK_CORE_PROJECT')
    client = bigquery.Client(project=project) if project else bigquery.Client()

    params = []
    for p in (args.parameter or []):
        params.append(parse_parameter(p))

    use_legacy = str(args.use_legacy_sql).lower() in ('true', '1', 'yes')
    job_config = bigquery.QueryJobConfig(
        query_parameters=params,
        use_legacy_sql=use_legacy,
    )

    print(f"[bq-shim] Running query (use_legacy_sql={use_legacy}, params={len(params)}, max_rows={args.max_rows})", file=sys.stderr)

    job = client.query(sql, job_config=job_config)
    result_iter = job.result(max_results=args.max_rows)
    schema = result_iter.schema
    rows = [_row_to_dict(row, schema) for row in result_iter]

    # bq's prettyjson uses 2-space indent, sort keys is implicit by insertion order.
    if args.format in ('prettyjson', 'pretty'):
        json.dump(rows, sys.stdout, indent=2, ensure_ascii=False)
        sys.stdout.write('\n')
    elif args.format == 'json':
        json.dump(rows, sys.stdout, ensure_ascii=False)
        sys.stdout.write('\n')
    else:
        # Fall back to prettyjson — orchestrator doesn't use other formats.
        json.dump(rows, sys.stdout, indent=2, ensure_ascii=False)
        sys.stdout.write('\n')


# ---------- main ----------

def main() -> int:
    if len(sys.argv) < 2:
        print("[bq-shim] Missing subcommand. Only `bq query` is supported.", file=sys.stderr)
        return 2

    sub = sys.argv[1]
    if sub == '--version':
        print("bq-shim (orchestrator-eval-plugin) using google-cloud-bigquery", file=sys.stderr)
        return 0
    if sub != 'query':
        print(f"[bq-shim] Subcommand {sub!r} not supported by this shim (only `bq query` is). "
              f"If the orchestrator started using a new bq subcommand, extend the shim.", file=sys.stderr)
        return 2

    parser = argparse.ArgumentParser(prog='bq query', add_help=False)
    # The orchestrator's flags. Anything else gets caught by REMAINDER and ignored.
    parser.add_argument('--use_legacy_sql', default='true')
    parser.add_argument('--format', default='pretty')
    parser.add_argument('--max_rows', type=int, default=100)
    parser.add_argument('--parameter', action='append', default=[])
    parser.add_argument('--project_id', default=None)
    parser.add_argument('--location', default=None)
    parser.add_argument('--nouse_cache', action='store_true')
    parser.add_argument('--help', '-h', action='store_true')
    args, extras = parser.parse_known_args(sys.argv[2:])

    if args.help:
        print(__doc__, file=sys.stderr)
        return 0

    # SQL source: stdin if piped, otherwise the leftover positional argument.
    if not sys.stdin.isatty():
        sql = sys.stdin.read()
    elif extras:
        sql = ' '.join(extras)
    else:
        print("[bq-shim] No SQL provided (expected stdin or positional argument).", file=sys.stderr)
        return 2

    try:
        query_command(args, sql)
    except Exception as e:
        print(f"[bq-shim] Query failed: {e.__class__.__name__}: {e}", file=sys.stderr)
        return 1
    return 0


if __name__ == '__main__':
    sys.exit(main())
